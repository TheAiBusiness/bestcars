# Producción — Bestcars_Back_DEF
# Copiar a .env y reemplazar valores

PORT=3001
NODE_ENV=production

# Orígenes permitidos (web + panel en producción)
CORS_ORIGINS=https://tudominio.com,https://panel.tudominio.com

# Base de datos: vacío = modo mock (solo lectura)
DATABASE_URL=

# ¡Obligatorio en producción: no dejar admin/admin!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=tu-password-seguro
JWT_SECRET=clave-minimo-32-caracteres-aleatoria

SENDGRID_API_KEY=
FROM_EMAIL=noreply@tudominio.com
RECIPIENT_EMAIL=ventas@tudominio.com
