// =============================================================================
// Prisma Schema - Best Cars Backend
// Base de datos: Supabase (PostgreSQL)
// Docs: https://pris.ly/d/prisma-schema
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Vehicle {
  id            String   @id
  title         String
  year          Int
  mileage       String
  price         String
  priceSubtext  String?  @map("price_subtext")
  fuelType      String?  @map("fuel_type")
  seats         String?
  description   String?  @db.Text
  images        String[]
  tags          String[]
  specifications Json?   // { general, motor, seguridad, tecnologia }
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  contactSubmissions ContactSubmission[]

  @@map("vehicles")
}

model ContactSubmission {
  id        Int      @id @default(autoincrement())
  vehicleId String?  @map("vehicle_id")
  name      String
  email     String
  phone     String?
  message   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@map("contact_submissions")
}

model TestDriveSubmission {
  id           Int      @id @default(autoincrement())
  vehicleId    String?  @map("vehicle_id")
  vehicleTitle String?  @map("vehicle_title")
  name         String
  age          String
  lastVehicle  String   @map("last_vehicle")
  interests    String   @db.Text
  mainUse      String   @map("main_use")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("test_drive_submissions")
}
