// =============================================================================
// Prisma Schema - Best Cars Backend
// Base de datos: Supabase (PostgreSQL)
// Docs: https://pris.ly/d/prisma-schema
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Vehicle {
  id            String   @id
  title         String
  year          Int
  mileage       String
  price         String
  priceSubtext  String?  @map("price_subtext")
  fuelType      String?  @map("fuel_type")
  seats         String?
  description   String?  @db.Text
  images        String[]
  tags          String[]
  specifications Json?   // { general, motor, seguridad, tecnologia }
  views         Int      @default(0)
  clicks        Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  contactSubmissions ContactSubmission[]

  @@map("vehicles")
}

model ContactSubmission {
  id        Int      @id @default(autoincrement())
  vehicleId String?  @map("vehicle_id")
  name      String
  email     String
  phone     String?
  message   String?  @db.Text
  status    String?  @default("new")  // new | contacted | follow_up | converted | lost
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@map("contact_submissions")
}

model TestDriveSubmission {
  id           Int      @id @default(autoincrement())
  vehicleId    String?  @map("vehicle_id")
  vehicleTitle String?  @map("vehicle_title")
  name         String
  age          String
  lastVehicle  String   @map("last_vehicle")
  interests    String   @db.Text
  mainUse      String   @map("main_use")
  status       String?  @default("new")
  notes        String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("test_drive_submissions")
}

model Scene {
  id            String   @id @default(cuid())
  name          String
  backgroundUrl String   @map("background_url")
  positions     Json     // { "parking-1": { vehicleId, transform, updatedAt }, ... }
  isActive      Boolean  @default(false) @map("is_active")
  order         Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("scenes")
}
