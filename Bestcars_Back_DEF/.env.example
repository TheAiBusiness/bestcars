# Server
PORT=3001
NODE_ENV=development

# CORS: orígenes permitidos (separados por coma)
# Frontend Vite dev: http://localhost:5173 | Producción: https://tudominio.com
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Supabase (PostgreSQL)
# Obtener en: Supabase Dashboard > Settings > Database > Connection string
# Si no usas DB, deja vacío: la API usará datos mock (car-1 a car-5)
DATABASE_URL=

# SendGrid (emails de contacto y test drive)
SENDGRID_API_KEY=
FROM_EMAIL=dev@theaibusiness.com
RECIPIENT_EMAIL=dev@theaibusiness.com
