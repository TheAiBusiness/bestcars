# Server
PORT=3001
NODE_ENV=development

# CORS: orígenes permitidos (separados por coma)
# Frontend Vite dev: 5173, 5174, 5175... | Producción: https://tudominio.com
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Supabase (PostgreSQL)
# Obtener en: Supabase Dashboard > Settings > Database > Connection string
# Si no usas DB, deja vacío: la API usará datos mock (car-1 a car-5)
DATABASE_URL=

# Autenticación del panel (usuario y contraseña: admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
JWT_SECRET=bestcars-panel-secret-change-in-production

# SendGrid (emails de contacto y test drive)
SENDGRID_API_KEY=
FROM_EMAIL=dev@theaibusiness.com
RECIPIENT_EMAIL=dev@theaibusiness.com
