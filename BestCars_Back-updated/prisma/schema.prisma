// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Vehicle {
  id            String   @id @default(cuid())
  title         String
  year          Int
  mileage       String
  price         String
  priceSubtext  String?  @map("price_subtext")
  fuelType      String?  @map("fuel_type")
  seats         String?
  description   String?  @db.Text
  images        String[] // Array of image URLs
  tags          String[] // Array of tags
  status        String   @default("available")
  priority      Int      @default(0)
  views         Int      @default(0)
  clicks        Int      @default(0)
  leads         Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  contactSubmissions ContactSubmission[]
  testDriveSubmissions TestDriveSubmission[]
  specifications     Specification[]

  @@map("vehicles")
}

model SpecificationCategory {
  id          String @id @default(uuid())
  name        String @unique // 'general', 'motor', 'seguridad', 'tecnologia'
  displayName String // 'General', 'Motor', 'Seguridad', 'Tecnología'
  icon        String? // Icon identifier for frontend
  order       Int    @default(0) // For ordering categories
  createdAt   DateTime @default(now()) @map("created_at")

  specifications Specification[]

  @@map("specification_categories")
}

model Specification {
  id          String @id @default(uuid())
  vehicleId   String
  categoryId  String
  key         String // 'Motor', 'Potencia', 'Tipo de carrocería', etc.
  value       String // '3.0L Turbo Bóxer 6', '443 HP @ 6,500 RPM', etc.
  order       Int    @default(0) // For ordering within category
  
  vehicle     Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  category    SpecificationCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([vehicleId])
  @@index([categoryId])
  @@map("specifications")
}

model ContactSubmission {
  id        Int      @id @default(autoincrement())
  vehicleId String?  @map("vehicle_id")
  name      String
  email     String
  phone     String?
  message   String?  @db.Text
  status    String   @default("new")
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@map("contact_submissions")
}

model TestDriveSubmission {
  id        Int      @id @default(autoincrement())
  vehicleId String?  @map("vehicle_id")
  name      String
  age       String
  lastVehicle String @map("last_vehicle")
  interests String
  mainUse   String  @map("main_use")
  status    String  @default("new")
  notes     String? @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@map("test_drive_submissions")
}

model Scene {
  id            String   @id @default(cuid())
  name          String
  backgroundUrl String   @map("background_url")
  positions     Json     // { "parking-1": { vehicleId, transform }, ... }
  isActive      Boolean  @default(false) @map("is_active")
  order         Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("scenes")
}
