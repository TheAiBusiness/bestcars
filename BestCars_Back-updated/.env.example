# Base de datos (Supabase PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# Puerto del servidor
PORT=3001

# CORS - Orígenes permitidos (separados por coma)
# Ejemplo: http://localhost:5173,http://localhost:5174,https://tudominio.com
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"

# Autenticación del panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=tu_contraseña_segura

# JWT (opcional, se genera uno por defecto si no se define)
JWT_SECRET=tu_clave_secreta_jwt

# Email (opcional - SendGrid)
# SENDGRID_API_KEY=
# FROM_EMAIL=noreply@bestcars.com
# RECIPIENT_EMAIL=ventas@bestcars.com
